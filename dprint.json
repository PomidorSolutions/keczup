{
  "markdown": {},
  "dockerfile": {},
  "biome": {
    "linter": {
      "rules": {
        "recommended": true,
        "style": {
          "useNamingConvention": {
            "level": "error",
            "options": {
              "strictCase": true,
              "conventions": [
                {
                  "selector": { "kind": "variable" },
                  "formats": ["camelCase", "CONSTANT_CASE"]
                },
                {
                  "selector": { "kind": "typeLike" },
                  "formats": ["PascalCase"]
                },
                {
                  "selector": { "kind": "function" },
                  "formats": ["camelCase", "PascalCase"]
                },
                {
                  "selector": { "kind": "objectLiteralProperty" },
                  "formats": ["camelCase", "snake_case"]
                }
              ]
            }
          }
        },
        "complexity": {
          "noExcessiveCognitiveComplexity": "warn"
        }
      }
    }
  },
  "malva": {},
  "markup": {},
  "yaml": {},
  "excludes": ["**/node_modules", "**/*-lock.json", "**/*.lock", "**/dist"],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
    "https://plugins.dprint.dev/biome-0.12.11.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.1.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
